{
    "name": "pdv",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "engines": {
        "node": "^20.19.0 || >=22.12.0"
    },
    "main": "dist-electron/main.js",
    "scripts": {
        "dev": "vite",
        "build": "run-p type-check \"build-only {@}\" --",
        "preview": "vite preview",
        "build-only": "vite build",
        "type-check": "vue-tsc --build",
        "lint": "eslint . --fix --cache",
        "copy:preload": "node scripts/copy-preload.js",
        "electron:dev": "concurrently -k \"npm run dev\" \"wait-on http://localhost:5173 && tsc -p electron/tsconfig.json && npm run copy:preload && electron .\"",
        "electron:build": "npm run build && tsc -p electron/tsconfig.json && npm run copy:preload && electron-builder",
        "electron:start": "electron ."
    },
    "build": {
        "appId": "com.pdv.app",
        "productName": "PDV App",
        "directories": {
            "output": "dist_electron"
        },
        "files": [
            "dist/**/*",
            "electron/**/*"
        ],
        "win": {
            "target": "nsis",
            "icon": "public/icon.ico"
        },
        "mac": {
            "target": "dmg",
            "icon": "public/icon.icns"
        },
        "linux": {
            "target": "AppImage",
            "icon": "public/icon.png"
        }
    },
    "dependencies": {
        "@primeuix/themes": "^2.0.2",
        "@tanstack/vue-table": "^8.21.3",
        "axios": "^1.13.2",
        "pinia": "^3.0.4",
        "primeflex": "^4.0.0",
        "primeicons": "^7.0.0",
        "primevue": "^4.5.3",
        "tailwind-merge": "^3.4.0",
        "tailwindcss-primeui": "^0.6.1",
        "vue": "^3.5.25",
        "vue-router": "^4.6.3"
    },
    "devDependencies": {
        "@tailwindcss/postcss": "^4.1.18",
        "@tsconfig/node24": "^24.0.3",
        "@types/node": "^24.10.1",
        "@vitejs/plugin-vue": "^6.0.2",
        "@vue/eslint-config-typescript": "^14.6.0",
        "@vue/tsconfig": "^0.8.1",
        "autoprefixer": "^10.4.22",
        "concurrently": "^9.2.1",
        "electron": "^39.2.7",
        "electron-builder": "^26.0.12",
        "electron-updater": "^6.6.2",
        "eslint": "^9.39.1",
        "eslint-plugin-vue": "~10.5.1",
        "jiti": "^2.6.1",
        "npm-run-all2": "^8.0.4",
        "postcss": "^8.5.6",
        "tailwindcss": "^4.1.18",
        "typescript": "~5.9.0",
        "vite": "^7.2.4",
        "vue-tsc": "^3.1.5",
        "wait-on": "^9.0.3"
    }
}
